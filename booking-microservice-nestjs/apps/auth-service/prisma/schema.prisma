generator client {
  provider = "prisma-client-js"
  //output   = "../../../libs/prisma-user/generated"   // Đường dẫn quan trọng
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_AUTH")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  codeId    String?  @unique
  expiresAt DateTime?
  isEmailVerified Boolean @default(false)

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @default(USER)
}